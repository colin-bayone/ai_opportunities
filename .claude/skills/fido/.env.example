# Meeting Transcript Skill - Environment Configuration
# Copy this file and fill in your values. NEVER commit the filled version.

# ============================================================
# REQUIRED: Azure App Registration
# ============================================================

# Azure AD application (client) ID
MICROSOFT_CLIENT_ID=your-client-id-here

# Azure AD application secret
MICROSOFT_CLIENT_SECRET=your-client-secret-here

# Azure AD tenant ID
AZURE_TENANT_ID=your-tenant-id-here

# ============================================================
# OPTIONAL: Graph API Configuration
# ============================================================

# Scopes for device code flow (comma-separated)
# Default: User.Read,Calendars.Read,OnlineMeetings.Read,OnlineMeetingTranscript.Read.All,offline_access
GRAPH_API_SCOPES=User.Read,Calendars.Read,OnlineMeetings.Read,OnlineMeetingTranscript.Read.All,offline_access

# Azure AD user object ID (ONLY needed for client credentials flow)
# Find this in Azure Portal > Users > your user > Object ID
# MICROSOFT_USER_ID=your-azure-ad-user-object-id

# ============================================================
# OPTIONAL: Defaults
# ============================================================

# How many days back to search when using --last (default: 30)
DEFAULT_SEARCH_DAYS=30

# Output directory relative to project root (default: claude/meeting_transcripts)
OUTPUT_DIR=claude/meeting_transcripts
